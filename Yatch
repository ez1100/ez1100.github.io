            lastScoredId = null; 
            isBotSurrenderIgnored = false; 
            
            if (Object.keys(diceTextures).length === 0) preRenderDiceTextures();
            if (Object.keys(oppDiceTextures).length === 0) preRenderOppDiceTextures(); 
            if (Object.keys(diceNumTextures).length === 0) preRenderDiceNumTextures(); 
            
            initDiceUI(); initScoreBoard(); resetTurnData(); updateUI();
        }

        function initDiceUI() {
            dice3DApps.forEach(app => disposeDiceApp(app));
            dice3DApps = [];

            const container = document.getElementById('diceContainer'); container.innerHTML = '';
            for(let i=0; i<5; i++) {
                let d = document.createElement('div'); 
                d.className = 'dice-3d-box'; 
                d.id = 'die-3d-'+i;
                d.onclick = () => toggleHold(i); 
                container.appendChild(d);
                initSingle3DDice('die-3d-'+i, i);
            }
        }

        function initScoreBoard() {
            const tableBody = document.getElementById('scoreTableBody');
            tableBody.innerHTML = ''; 
            
            const createRow = (cat) => {
                let maxStr = cat.type === 'fix' ? `${cat.maxVal} ${t.fixTxt}` : `${t.maxTxt} ${cat.maxVal}`;
                return `<tr>
                <td class="cat-name"><i class="fa-solid ${cat.icon}"></i> ${cat.name} <span class="max-score">${maxStr}</span></td>
                <td id="my-${cat.id}" class="score-cell" onclick="selectScore('${cat.id}')"></td>
                <td id="opp-${cat.id}" class="score-cell"></td></tr>`;
            };

            upperCategories.forEach(cat => tableBody.innerHTML += createRow(cat));

            tableBody.innerHTML += `
                <tr class="bonus-row">
                    <td class="cat-name" style="background-color: #ebf5fb;"><i class="fa-solid fa-calculator"></i> ${t.subtotalTxt}</td>
                    <td id="my-subtotal">0 / 63</td>
                    <td id="opp-subtotal">0 / 63</td>
                </tr>
                <tr class="bonus-row" id="bonus-status-row">
                    <td class="cat-name" style="line-height: 1.4; background-color: #ebf5fb;"><i class="fa-solid fa-gift"></i> ${t.bonusTxt}</td>
                    <td id="my-bonus-val">0</td>
                    <td id="opp-bonus-val">0</td>
                </tr>
            `;

            lowerCategories.forEach(cat => tableBody.innerHTML += createRow(cat));
            
            categories.forEach(cat => {
                let m = document.getElementById(`my-${cat.id}`), o = document.getElementById(`opp-${cat.id}`);
                if(oppScores[cat.id] !== undefined) { o.innerText = oppScores[cat.id]; o.className = 'score-cell filled'; }
                if(myScores[cat.id] !== undefined) { m.innerText = myScores[cat.id]; m.className = 'score-cell filled'; }
            });
        }

        function playRollingAnimation(targetValues, callback) {
            for(let i=0; i<5; i++) {
                if(!isHeld[i]) animate3DDiceRoll(i, targetValues[i]);
            }
            setTimeout(() => { if(callback) callback(); }, 900);
        }

        function rollDice() {
            if(!isMyTurn || rollsLeft <= 0 || isRolling) return;
            
            isRolling = true; updateUI(); 
            let newValues = [...diceValues];
            for(let i=0; i<5; i++) if(!isHeld[i]) newValues[i] = Math.floor(Math.random()*6)+1;
            rollsLeft--; 
            
            if(conn && !isBotMode) conn.send({ type: 'SYNC_ROLL', diceValues: newValues, rollsLeft });

            playRollingAnimation(newValues, () => {
                diceValues = newValues; isRolling = false;
                updateUI(); checkAndPlayYachtEffect();
            });
        }

        function toggleHold(index) {
            if(!isMyTurn || rollsLeft === 3 || isRolling) return;
            isHeld[index] = !isHeld[index]; updateUI();
            if(conn && !isBotMode) conn.send({ type: 'SYNC_HOLD', index, isHeld: isHeld[index] });
        }

        function surrender() {
            if(isRolling) return;
            if(!confirm(t.surrenderAlert)) return;
            if(isBotMode) { showVictoryScreen(oppNickname); return; }
            if(conn) conn.send({ type: 'SURRENDER' });
            showVictoryScreen(oppNickname); 
        }

        function handleOpponentSurrender() { 
            alert(t.oppSurrenderAlert); 
            showVictoryScreen(myNickname); 
        }

        function selectScore(catId) {
            if(!isMyTurn || rollsLeft === 3 || myScores[catId] !== undefined || isRolling) return;
            
            let p = getPotentialScores(); myScores[catId] = p[catId];
            lastScoredId = `my-${catId}`; 

            if(conn && !isBotMode) conn.send({ type: 'SYNC_SCORE', category: catId, score: myScores[catId] });
            
            isMyTurn = false; resetTurnData(); updateUI();
            if (isBotMode && !checkGameEnd()) { setTimeout(runBotLogic, 1300); } 
            else { checkGameEnd(); }
        }

        function checkGameEnd() {
            if(Object.keys(myScores).length === 12 && Object.keys(oppScores).length === 12) {
                let my = calculateScores(myScores).total, opp = calculateScores(oppScores).total;
                showVictoryScreen(my > opp ? myNickname : (opp > my ? oppNickname : "무승부")); return true;
            }
            return false;
        }

        function checkBotSurrenderCondition() {
            if (!isBotMode || isBotSurrenderIgnored) return false;

            let playerTotal = calculateScores(myScores).total;
            let botCurrentUpper = 0; let botEmptyUpperMax = 0; let botEmptyLowerMax = 0;

            const maxValues = {
                'aces': 5, 'twos': 10, 'threes': 15, 'fours': 20, 'fives': 25, 'sixes': 30,
                'choice': 30, '4ofakind': 30, 'fullhouse': 30, 'sstraight': 15, 'lstraight': 30, 'yacht': 50
            };
            const upperKeys = ['aces', 'twos', 'threes', 'fours', 'fives', 'sixes'];

            for (let cat of categories) {
                let key = cat.id;
                if (oppScores[key] !== undefined) {
                    if (upperKeys.includes(key)) botCurrentUpper += oppScores[key];
                } else {
                    if (upperKeys.includes(key)) botEmptyUpperMax += maxValues[key];
                    else botEmptyLowerMax += maxValues[key];
                }
            }

            let botBonus = (botCurrentUpper + botEmptyUpperMax >= 63) ? 35 : 0;
            let botCurrentTotalNoBonus = Object.values(oppScores).reduce((a, b) => a + b, 0);
            let botMaxPossibleTotal = botCurrentTotalNoBonus + botEmptyUpperMax + botEmptyLowerMax + botBonus;

            return (botMaxPossibleTotal < playerTotal);
        }

        function runBotLogic() {
            if (isMyTurn || checkGameEnd() || isRolling) return;
            
            if (checkBotSurrenderCondition()) {
                setTimeout(() => {
                    document.getElementById('botSurrenderBanner').classList.add('show');
                }, 400);
                return;
            }
            
            if (rollsLeft === 3) { 
                botRollDice(() => { setTimeout(runBotLogic, 1200); }); 
            } else if (rollsLeft > 0) { 
                botDecideHolds(); 
                setTimeout(() => { botRollDice(() => { setTimeout(runBotLogic, 1200); }); }, 900);
            } else { 
                setTimeout(botSelectScore, 600);
            }
        }

        function acceptBotSurrender() {
            document.getElementById('botSurrenderBanner').classList.remove('show');
            showVictoryScreen(myNickname);
        }

        function refuseBotSurrender() {
            document.getElementById('botSurrenderBanner').classList.remove('show');
            isBotSurrenderIgnored = true; 
            
            if (rollsLeft === 3) { 
                botRollDice(() => { setTimeout(runBotLogic, 1200); }); 
            } else if (rollsLeft > 0) { 
                botDecideHolds(); 
                setTimeout(() => { botRollDice(() => { setTimeout(runBotLogic, 1200); }); }, 900);
            } else { 
                setTimeout(botSelectScore, 600);
            }
        }

        function getMistakeChance() {
            const rates = [30, 15, 5, 0]; 
            return rates[Math.min(botLevel - 1, 3)];
        }

        function botRollDice(callback) { 
            isRolling = true; updateUI();
            let newValues = [...diceValues];
            for(let i=0; i<5; i++) { if(!isHeld[i]) newValues[i] = Math.floor(Math.random()*6)+1; } 
            rollsLeft--; 
            
            playRollingAnimation(newValues, () => {
                diceValues = newValues; isRolling = false;
                updateUI(); checkAndPlayYachtEffect();
                if(callback) callback();
            });
        }
        
        function botDecideHolds() {
            let mistake = getMistakeChance();
            if (Math.random() * 100 < mistake) {
                for(let i=0; i<5; i++) { isHeld[i] = Math.random() > 0.5; }
            } else {
                let counts = [0, 0, 0, 0, 0, 0, 0]; 
                diceValues.forEach(d => counts[d]++);
                
                let maxFreq = 0;
                let targetNum = 1;
                for (let num = 1; num <= 6; num++) {
                    if (counts[num] > maxFreq) {
                        maxFreq = counts[num];
                        targetNum = num;
                    }
                }
                for(let i=0; i<5; i++) { isHeld[i] = (diceValues[i] === targetNum); }
            }
            updateUI();
        }

        function botSelectScore() {
            try {
                let p = getPotentialScores(); 
                let bestCat = null; let bestScore = -1;
                let mistake = getMistakeChance();
                let availableCats = categories.filter(c => oppScores[c.id] === undefined);

                if (Math.random() * 100 < mistake && availableCats.length > 0) {
                    bestCat = availableCats[Math.floor(Math.random() * availableCats.length)].id;
                } else {
                    for (let cat of categories) {
                        if (oppScores[cat.id] === undefined && p[cat.id] > bestScore) { bestScore = p[cat.id]; bestCat = cat.id; }
                    }
                    if (bestScore === 0 || bestCat === null) {
                        const sacrificeOrder = ['aces','twos','threes','fours','4ofakind','choice','fullhouse','sstraight','lstraight','fives','sixes','yacht'];
                        for (let catId of sacrificeOrder) { if (oppScores[catId] === undefined) { bestCat = catId; break; } }
                    }
                }

                if(bestCat !== null) {
                    oppScores[bestCat] = p[bestCat];
                    lastScoredId = `opp-${bestCat}`;
                }
            } catch (e) {
                const remainCats = categories.filter(c => oppScores[c.id] === undefined);
                if(remainCats.length > 0) {
                    oppScores[remainCats[0].id] = 0;
                    lastScoredId = `opp-${remainCats[0].id}`;
                }
            }
            isMyTurn = true; resetTurnData(); updateUI(); checkGameEnd();
        }

        function getPotentialScores() {
            let counts = [0,0,0,0,0,0,0]; let sum = 0; diceValues.forEach(d => { counts[d]++; sum += d; });
            let p = {};
            p['aces'] = counts[1]*1; p['twos'] = counts[2]*2; p['threes'] = counts[3]*3; p['fours'] = counts[4]*4; p['fives'] = counts[5]*5; p['sixes'] = counts[6]*6;
            p['choice'] = sum;
            p['4ofakind'] = counts.some(c => c >= 4) ? sum : 0;
            p['fullhouse'] = (counts.some(c => c === 3) && counts.some(c => c === 2)) || counts.some(c => c === 5) ? sum : 0;
            let s = counts.slice(1).map(c => c>0?1:0).join('');
            p['sstraight'] = s.includes('1111') || s.includes('11110') || s.includes('01111') ? 15 : 0; 
            p['lstraight'] = s.includes('11111') ? 30 : 0;
            p['yacht'] = counts.some(c => c === 5) ? 50 : 0;
            return p;
        }

        // [변경] 버튼 위치 이동에 따른 실시간 아이콘 스위칭 핸들러 갱신
function toggleDiceMode() {
    currentDiceMode = (currentDiceMode === 'dot') ? 'number' : 'dot';
    
    const btnText = document.getElementById('diceModeBtnText');
    const btnIcon = document.getElementById('diceModeIcon');
    
    if (currentDiceMode === 'dot') {
        if (btnText) btnText.innerText = "숫자 모드로 전환";
        if (btnIcon) btnIcon.className = "fa-solid fa-square-1"; // 사각형 안의 숫자 1
    } else {
        if (btnText) btnText.innerText = "점 모드로 전환";
        if (btnIcon) btnIcon.className = "fa-solid fa-dice-one";  // 점 1개 주사위
    }
    updateUI(); 
}

        function calculateScores(scoresObj) {
            let upper = ['aces','twos','threes','fours','fives','sixes'].reduce((a,c) => a+(scoresObj[c]||0), 0);
            let bonus = upper >= 63 ? 35 : 0;
            let total = Object.values(scoresObj).reduce((a,b)=>a+b, 0) + bonus;
            return { upper, bonus, total };
        }

        function updateUI() {
            const isOppTurn = !isMyTurn; 

            for(let i=0; i<5; i++) {
                let box = document.getElementById('die-3d-'+i);
                let app = dice3DApps[i];
                if (box && app) {
                    if (isHeld[i]) box.className = 'dice-3d-box held';
                    else box.className = 'dice-3d-box';

                    let currentMaterials;
                    if (isOppTurn) {
                        currentMaterials = (currentDiceMode === 'number') ?
                            [oppDiceNumTextures[3], oppDiceNumTextures[4], oppDiceNumTextures[2], oppDiceNumTextures[5], oppDiceNumTextures[1], oppDiceNumTextures[6]] :
                            [oppDiceTextures[3], oppDiceTextures[4], oppDiceTextures[2], oppDiceTextures[5], oppDiceTextures[1], oppDiceTextures[6]];
                    } else {
                        currentMaterials = (currentDiceMode === 'number') ?
                            [diceNumTextures[3], diceNumTextures[4], diceNumTextures[2], diceNumTextures[5], diceNumTextures[1], diceNumTextures[6]] :
                            [diceTextures[3], diceTextures[4], diceTextures[2], diceTextures[5], diceTextures[1], diceTextures[6]];
                    }
                    
                    app.mesh.material = currentMaterials; 
                }
            }

            const turnElement = document.getElementById('turnText');
            if(isMyTurn) {
                turnElement.innerText = isRolling ? "..." : t.myTurn;
                turnElement.style.color = "#2ecc71";
                turnElement.classList.remove('opp-turn');
            } else {
                turnElement.innerText = isBotMode ? t.botThinking : `⌛ ${oppNickname}${t.oppTurn}`;
                turnElement.style.color = "#e74c3c";
                turnElement.classList.add('opp-turn');
            }
            
            document.getElementById('rollBtn').disabled = !isMyTurn || rollsLeft <= 0 || isRolling;
            document.getElementById('surrenderBtn').disabled = !isMyTurn || isRolling;
            document.getElementById('rollsLeftText').innerText = rollsLeft;

            let myPot = getPotentialScores();
            categories.forEach(cat => {
                let m = document.getElementById(`my-${cat.id}`), o = document.getElementById(`opp-${cat.id}`);
                o.innerText = oppScores[cat.id] !== undefined ? oppScores[cat.id] : '';
                o.className = 'score-cell' + (oppScores[cat.id] !== undefined ? ' filled' : '');
                
                if(myScores[cat.id] !== undefined) { 
                    m.innerText = myScores[cat.id]; m.className = 'score-cell filled'; 
                } else if(isMyTurn && rollsLeft < 3 && !isRolling) { 
                    m.innerText = myPot[cat.id]; m.className = 'score-cell potential'; 
                } else { 
                    m.innerText = ''; m.className = 'score-cell'; 
                }

                if (lastScoredId === `my-${cat.id}`) m.classList.add('last-scored');
                if (lastScoredId === `opp-${cat.id}`) o.classList.add('last-scored');
            });

            let myRes = calculateScores(myScores), oppRes = calculateScores(oppScores);
            document.getElementById('my-subtotal').innerText = `${myRes.upper} / 63`;
            document.getElementById('opp-subtotal').innerText = `${oppRes.upper} / 63`;
            document.getElementById('my-bonus-val').innerText = myRes.bonus;
            document.getElementById('opp-bonus-val').innerText = oppRes.bonus;
            document.getElementById('my-total').innerText = myRes.total;
            document.getElementById('opp-total').innerText = oppRes.total;

            const myBonusEl = document.getElementById('my-bonus-val');
            const oppBonusEl = document.getElementById('opp-bonus-val');
            if(myRes.upper >= 63) myBonusEl.className = 'score-cell filled bonus-achieved';
            else myBonusEl.classList.remove('bonus-achieved');
            if(oppRes.upper >= 63) oppBonusEl.className = 'score-cell filled bonus-achieved';
            else oppBonusEl.classList.remove('bonus-achieved');
        }

        function showVictoryScreen(winner) {
            document.getElementById('gameover-overlay').classList.add('show');
            document.getElementById('actionButtons').style.display = 'none'; 
            document.getElementById('botSurrenderBanner').classList.remove('show'); 

            lastWinner = winner; 
            let isWin = winner === myNickname;
            let isDraw = winner === "무승부";
            let isBotWin = winner === oppNickname && isBotMode;

            const levelUpBtn = document.getElementById('levelUpBtn');
            const rematchBtn = document.getElementById('rematchBtn');
            
            if (isBotMode) {
                rematchBtn.innerText = t.retryBtnTxt; 
                if (isWin) levelUpBtn.style.display = 'block'; 
                else levelUpBtn.style.display = 'none';
            } else {
                levelUpBtn.style.display = 'none';
                rematchBtn.innerText = t.rematchBtnTxt; 
            }

            const diceCont = document.getElementById('diceContainer');
            if(isDraw) diceCont.innerHTML = `<div class="result-dice-text" style="color:#bdc3c7;">${t.draw}</div>`;
            else if(isWin) diceCont.innerHTML = `<div class="result-dice-text" style="color:#2ecc71;">${t.win}</div>`;
            else diceCont.innerHTML = `<div class="result-dice-text" style="color:#e74c3c;">${t.lose}</div>`;
            
            let wText = isDraw ? t.draw : `🎉 ${winner} ${t.winMsg} 🎉`;
            if (isBotWin) wText = t.botLose; 
            if (sysLang === 'ko' && !isDraw && !isBotWin) wText = `🎉 ${winner} 승리!`;
            
            document.getElementById('winnerText').innerText = wText;
            document.getElementById('finalScoreMsg').innerText = `${t.myTxtStr}: ${calculateScores(myScores).total} | ${t.oppTxtStr}: ${calculateScores(oppScores).total}`;
            
            amIWantRematch = false; isOppWantRematch = false;
            document.getElementById('rematchStatus').innerText = ""; document.getElementById('rematchBtn').disabled = false;
        }

        function requestRematch() {
            if(isBotMode) {
                let starter = (lastWinner === myNickname) ? oppNickname : myNickname;
                oppNickname = t.botName + " Lv." + botLevel;
                document.getElementById('p2Name').innerText = oppNickname;
                resetFullGame(starter); if(!isMyTurn) setTimeout(runBotLogic, 1500); return;
            }
            amIWantRematch = true; document.getElementById('rematchBtn').disabled = true;
            if(conn) conn.send({ type: 'REMATCH_PUSH' });
            handleRematchLogic();
        }

        function triggerLevelUpRematch() {
            if(isBotMode) {
                botLevel++;
                oppNickname = t.botName + " Lv." + botLevel;
                document.getElementById('p2Name').innerText = oppNickname;
                let starter = oppNickname; 
                resetFullGame(starter); 
                if(!isMyTurn) setTimeout(runBotLogic, 1500); 
            }
        }

        function handleRematchLogic() {
            if(amIWantRematch && isOppWantRematch) {
                let starter = (lastWinner === myNickname) ? oppNickname : myNickname;
                if(isHost) { if(conn) conn.send({ type: 'REMATCH_START', starterNickname: starter }); resetFullGame(starter); }
            } else { 
                let waitTxt = sysLang === 'ko' ? "상대방의 수락을 기다리고 있습니다..." : "Waiting for opponent..."; 
                document.getElementById('rematchStatus').innerText = waitTxt; 
            }
        }

        function resetFullGame(starterNickname) { isMyTurn = (starterNickname === myNickname); startGame(); }
        
        function resetTurnData() { 
            diceValues = [1,1,1,1,1]; 
            isHeld = [false,false,false,false,false]; 
            rollsLeft = 3; 
            
            for(let i=0; i<5; i++){
                if(dice3DApps[i]){
                    dice3DApps[i].targetX = 0.45;
                    dice3DApps[i].targetY = 0.90;
                    dice3DApps[i].targetZ = 0;
                }
            }
        }
        function switchView(id) { document.querySelectorAll('.view').forEach(v=>v.classList.remove('active')); document.getElementById(id).classList.add('active'); }
        window.addEventListener('beforeunload', () => { if(conn && conn.open) conn.close(); });
    </script>
</body>
