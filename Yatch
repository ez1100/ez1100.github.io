<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">

    <title>Yacht Dice - v2.4.4 Master Edition</title>
    
    <script src="https://unpkg.com/peerjs@1.5.4/dist/peerjs.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <style>
        * { box-sizing: border-box; }
        body { font-family: 'Pretendard', sans-serif; text-align: center; background-color: #1a252f; color: white; margin: 0; padding: 15px; overflow-x: hidden; position: relative; }
        .view { display: none; }
        .active { display: block; }
        #fireworksCanvas { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; pointer-events: none; z-index: 9999; }

        .title-wrapper { margin-top: 30px; margin-bottom: 20px; }
        h2 { font-size: clamp(24px, 6.5vw, 65px); margin: 0; display: inline-block; text-shadow: 2px 2px 5px rgba(0,0,0,0.4); vertical-align: middle; white-space: nowrap; }
        .ver-badge { background-color: #f1c40f; color: #1a252f; padding: 3px 8px; border-radius: 4px; font-size: 14px; font-weight: bold; vertical-align: middle; margin-left: 8px; }
        
        .lang-selector { 
            display: block; margin: 15px auto 0 auto; width: 500px; max-width: 100%; 
            background-color: #34495e; color: white; border: 1px solid #bdc3c7; 
            border-radius: 8px; padding: 12px; font-size: 15px; cursor: pointer; 
            outline: none; transition: 0.2s; 
        }
        .lang-selector:focus { border-color: #f1c40f; }

        .patch-notes { 
            width: 500px; max-width: 100%; margin: 15px auto 0 auto; 
            background-color: #2c3e50; border-radius: 8px; padding: 12px 15px; 
            text-align: left; font-size: 12px; color: #bdc3c7; 
            max-height: 110px; overflow-y: auto; line-height: 1.6; border: 1px solid #3b536b;
        }
        .patch-notes::-webkit-scrollbar { width: 6px; }
        .patch-notes::-webkit-scrollbar-thumb { background-color: #7f8c8d; border-radius: 3px; }

        /* [변경] 버튼 기본 디자인 컴포넌트화 및 액션 버튼 크기 밸런싱 세팅 */
        button { padding: 12px 16px; font-size: 15px; font-weight: bold; cursor: pointer; border: none; border-radius: 8px; transition: 0.3s; margin: 0; }
        .btn-red { background-color: #e74c3c; color: white; } .btn-red:hover { background-color: #c0392b; }
        .btn-green { background-color: #2ecc71; color: white; }
        .btn-blue { background-color: #3498db; color: white; }
        .btn-purple { background-color: #9b59b6; color: white; } .btn-purple:hover { background-color: #8e44ad; }
        button:disabled { background-color: #7f8c8d; cursor: not-allowed; opacity: 0.6; }

        .dice-area-wrapper { position: relative; max-width: 450px; margin: 20px auto; }
        .dice-container { display: flex; justify-content: center; align-items: center; gap: 12px; min-height: 80px; flex-wrap: wrap; }
        .dice-3d-box { width: 78px; height: 78px; position: relative; cursor: pointer; border-radius: 12px; transition: 0.1s; background-color: rgba(255,255,255,0.03); border: 2px solid transparent; box-sizing: border-box; }
        .dice-3d-box.held { border-color: #f1c40f; background-color: rgba(241, 196, 15, 0.1); transform: translateY(5px); }
        .dice-3d-box canvas { width: 100% !important; height: 100% !important; display: block; border-radius: 10px; }

        .bot-surrender-banner { 
            display: none; 
            position: absolute; 
            top: 0; left: 0; 
            width: 100%; height: 100%; 
            background: linear-gradient(135deg, #2c3e50 0%, #1a252f 100%); 
            border: 2px dashed #e74c3c; 
            border-radius: 12px; 
            z-index: 10; 
            align-items: center; 
            justify-content: center; 
            flex-direction: column; 
            padding: 10px;
            box-sizing: border-box;
            animation: popHighlight 0.4s ease-out;
        }
        .bot-surrender-banner.show { display: flex; }
        .bot-surrender-banner p { margin: 0 0 8px 0; font-size: 13px; font-weight: bold; color: #ff9f89; line-height: 1.4; word-break: keep-all; }
        .bot-surrender-banner .btn-group { display: flex; gap: 8px; width: 100%; justify-content: center; }
        .bot-surrender-banner button { padding: 6px 12px; font-size: 12px; margin: 0; }

        .result-dice-text { font-size: 36px; font-weight: 900; text-shadow: 2px 2px 8px rgba(0,0,0,0.5); animation: popHighlight 0.5s ease-out; }

        table { margin: 15px auto; border-collapse: collapse; width: 100%; max-width: 450px; background-color: #fff; color: #333; border-radius: 10px; overflow: hidden; table-layout: fixed; }
        th, td { border: 1px solid #ddd; padding: 8px 5px; text-align: center; }
        th { background-color: #2c3e50; color: white; font-size: 14px; }
        
        .cat-name { text-align: left; background-color: #f8f9fa; font-weight: bold; font-size: 13px; width: 44%; position: relative; }
        .cat-name i { margin-right: 6px; color: #555; }
        .max-score { color: #95a5a6; font-size: 11px; float: right; font-weight: normal; line-height: 1.5; }
        
        .score-cell { font-weight: bold; width: 28%; font-size: 16px; transition: 0.2s; height: 38px; }
        .score-cell.potential { color: #2ecc71; background-color: #f0fff0; cursor: pointer; }
        .score-cell.potential:hover { background-color: #d4edd5; }
        .score-cell.filled { color: #2c3e50; background-color: #f8f9fa; }

        @keyframes popHighlight { 0% { transform: scale(1); } 50% { transform: scale(1.03); } 100% { transform: scale(1); } }
        .score-cell.last-scored { background-color: #fff3cd !important; color: #d35400 !important; border: 2px solid #f1c40f; animation: popHighlight 0.4s ease-out; box-shadow: inset 0 0 10px rgba(241, 196, 15, 0.3); }

        .bonus-row { background-color: #ebf5fb; font-size: 13px; font-weight: bold; }
        .bonus-achieved { background-color: #f1c40f !important; color: #000 !important; font-weight: bold; }

        .guide-section { width: 100%; max-width: 450px; margin: 20px auto; text-align: left; background-color: #2c3e50; padding: 15px; border-radius: 10px; font-size: 12px; line-height: 1.5; color: #bdc3c7; }
        .guide-section h4 { color: #f1c40f; margin-top: 0; margin-bottom: 10px; }
        
        input { max-width: 100%; width: 500px; padding: 12px; border-radius: 8px; border: none; text-align: center; font-size: 16px; margin-bottom: 10px; }
        .code-box { background-color: #34495e; padding: 15px; border-radius: 8px; display: inline-block; margin: 15px 0; font-family: monospace; word-break: break-all; max-width: 100%; cursor: pointer; transition: 0.2s; border: 2px dashed transparent; }
        .code-box:hover { background-color: #3b536b; border-color: #bdc3c7; }
        .code-box:active { background-color: #2c3e50; transform: scale(0.98); }
        .copy-hint { font-size: 12px; color: #bdc3c7; margin-top: 8px; font-weight: bold; }
        .status-msg { font-size: 18px; font-weight: bold; margin: 10px 0; color: #f1c40f; min-height: 27px; }
        .status-msg.opp-turn { color: #e74c3c !important; }
        
        .error-msg { color: #e74c3c; font-size: 14px; font-weight: bold; margin-top: 12px; display: none; animation: popHighlight 0.3s ease-out; }
        
        /* [변경] 조작 버튼 그룹 정렬 컨테이너 가로 대응 최적화 */
#actionButtons { 
    display: flex; 
    justify-content: center; 
    align-items: center; 
    gap: 8px; 
    margin: 0 auto 15px auto; 
    width: 100%; 
    max-width: 450px; 
}
/* 모드 전환 버튼 스타일 및 레이아웃 균등 분할 */
#modeToggleBtn { 
    background-color: #34495e; 
    color: white; 
    border: 1px solid #7f8c8d; 
    flex: 1.1; 
    white-space: nowrap; 
    font-size: 13px; 
}
#modeToggleBtn:hover { background-color: #4f6b85; }
#rollBtn { flex: 1.2; white-space: nowrap; font-size: 14px; }
#surrenderBtn { flex: 0.7; background-color: #7f8c8d; white-space: nowrap; }

        .overlay { 
            display: none; 
            position: fixed; 
            top: 0; left: 0; 
            width: 100vw; 
            height: 100vh; 
            background-color: rgba(15, 23, 30, 0.75); 
            z-index: 1000; 
            justify-content: center; 
            align-items: center; 
            padding: 20px;
            box-sizing: border-box;
        }
        .overlay.show { display: flex; }

        .result-box { 
            background-color: #2c3e50; 
            padding: 22px; 
            border-radius: 15px; 
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5); 
            border: 2px solid #f1c40f; 
            width: 95%; 
            max-width: 420px; 
            max-height: 80vh; 
            overflow-y: auto; 
            box-sizing: border-box;
        }
        @media (max-width: 500px) {
            .title-wrapper { margin-top: 25px; margin-bottom: 15px; }
            h2 { font-size: 24px; } 
            .ver-badge { font-size: 11px; padding: 2px 6px; margin-left: 4px; }
            button { padding: 12px 10px; font-size: 13px; }
            #modeToggleBtn { font-size: 11px; }
            #rollBtn { font-size: 11px; }
            #surrenderBtn { font-size: 11px; }
        }
    </style>
</head>
<body>

    <canvas id="fireworksCanvas"></canvas>

    <div class="title-wrapper">
            <span class="ver-badge">v2.4.4 Master</span>
            <br>
        <h2 data-i18n="mainTitle">🎲 YACHT DICE ONLINE 🎲</h2>
    </div>

    <div id="login-view" class="view active">
        <p data-i18n="nicknameGuide" style="color: #bdc3c7; font-size: 15px; margin-bottom: 15px; font-weight: bold;">
            상대방에게 보여질 닉네임을 입력해 주세요.
        </p>
        <input type="text" id="nicknameInput" data-i18n="idPlaceholder" placeholder="아이디 입력 (빈칸 시 랜덤)"><br>
        <button class="btn-red" onclick="enterLobby()" data-i18n="loginBtn" style="width: 500px; max-width: 100%; margin: 5px 0;">게임 접속</button>

        <select id="langSelect" class="lang-selector" onchange="changeLanguage(this.value)">
            <option value="ko">🇰🇷 한국어 (Korean)</option>
            <option value="en">🇺🇸 English</option>
        </select>

        <div class="patch-notes">
            <div style="font-weight:bold; color:white; margin-bottom:6px;"><i class="fa-solid fa-bullhorn" style="color:#f1c40f;"></i> <span data-i18n="patchTitle">업데이트 내역</span></div>
            • <b>v2.4.3</b> : 주사위 모드 전환 버튼 하단 인터페이스 레이아웃 편입 및 아이콘 스위칭 최적화 적용<br>
            • <b>v2.4.2</b> : 주사위 인터페이스 내장형 '전의상실 인라인 배너' 개편<br>
            • <b>v2.4.0</b> : Three.js 메모리 누수 방지, 주사위 리셋 물리 보정, 알파다이스 인공지능 벨런싱 패치<br>
            • <b>v2.3.2</b> : 상대편의 주사위 컬러변경, 알파다이스 버그수정<br>
            • <b>v2.3.1</b> : 난이도 조절, 주사위 3d 연출로 교체, 사이즈 확대<br>
            • <b>v2.3.0</b> : P2P 10초 타임아웃 & 에러 핸들링 탑재<br>
            • <b>v2.2.0</b> : 알파다이스 진화 알고리즘 (황금 실수율 커브)<br>
            • <b>v2.1.0</b> : 대전 보상 선택지 (강화 훈련 / 반복 훈련)<br>
            • <b>v2.0.0</b> : 글로벌 5개국어 지원 & 스크린샷 현지화<br>
            • <b>v1.5.0</b> : 모바일 컴팩트 UI & 테이블 줄바꿈 방지<br>
            • <b>v1.0.0</b> : 실시간 온라인 대전 & 봇 조기 기권 탑재        </div>
    </div>

    <div id="lobby-view" class="view">
        <h3 id="welcomeText" style="margin-top: 5px; margin-bottom: 10px;"></h3>
        <div class="code-box" onclick="copyMyCode()" title="Copy">
            <span data-i18n="myCodeTxt">내 관리 코드:</span><br>
            <span id="myCodeDisplay" style="color: #f1c40f; font-size: 18px;">Loading...</span>
            <div id="copyHint" class="copy-hint" data-i18n="copyHintTxt"><i class="fa-regular fa-copy"></i> 터치해서 복사하기</div>
        </div><br>
        <input type="text" id="oppCodeInput" data-i18n="oppPlaceholder" placeholder="상대방 코드 입력 (빈칸 시 봇전)"><br>
        <button id="connectBtn" class="btn-blue" onclick="connectToOpponent()" disabled data-i18n="startBtn" style="width: 500px; max-width: 100%; margin-top: 10px;">게임 시작</button>
        <div id="connectionErrorMsg" class="error-msg"></div>
    </div>

    <div id="game-view" class="view">
        <div id="turnText" class="status-msg" data-i18n="waiting">대기 중...</div>
        
        <div class="dice-area-wrapper">
            <div class="dice-container" id="diceContainer"></div>
            
            <div id="botSurrenderBanner" class="bot-surrender-banner">
                <p id="botSurrenderText">🤖 압도적인 패배에 전의를 상실했습니다..</p>
                <div class="btn-group">
                    <button class="btn-red" onclick="acceptBotSurrender()">🏳️ 기권 수락</button>
                    <button class="btn-green" onclick="refuseBotSurrender()" style="background-color: #27ae60;">🔥 참교육</button>
                </div>
            </div>
        </div>
        
        <div id="actionButtons">
    <button id="modeToggleBtn" onclick="toggleDiceMode()">
        <i id="diceModeIcon" class="fa-solid fa-square-1"></i> <span id="diceModeBtnText">숫자 모드로 전환</span>
    </button>
    <button id="rollBtn" class="btn-red" onclick="rollDice()"><span data-i18n="rollBtnTxt">주사위 굴리기</span> (<span id="rollsLeftText">3</span>/3)</button>
    <button id="surrenderBtn" class="btn-blue" onclick="surrender()" data-i18n="surrenderBtnTxt">기권</button>
</div>

       <table id="scoreBoard">
            <thead>
                <tr>
                    <th data-i18n="catTitle">Categories</th>
                    <th id="p1Name">나</th>
                    <th id="p2Name">상대</th>
                </tr>
            </thead>
            <tbody id="scoreTableBody"></tbody>
            <tfoot>
                <tr style="background-color: #2c3e50; color: white;">
                    <th>TOTAL</th>
                    <th id="my-total">0</th>
                    <th id="opp-total">0</th>
                </tr>
            </tfoot>
        </table>
        
        <div class="guide-section" id="guideSection">
            <h4 data-i18n="guideTitle"><i class="fa-solid fa-book"></i> 점수 계산 방법</h4>
            <div id="guide-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
                <div data-i18n="guideLeft">
                    <b>• Aces~Sixes:</b> 해당 숫자들의 합<br>
                    <b>• Choice:</b> 모든 주사위의 합<br>
                    <b>• 4 of a Kind:</b> 4개 이상 동일 (전체 합)<br>
                    <b>• Full House:</b> 3개 + 2개 동일 (전체 합)
                </div>
                <div data-i18n="guideRight">
                    <b>• S. Straight:</b> 4개 연속 숫자 (15점)<br>
                    <b>• L. Straight:</b> 5개 연속 숫자 (30점)<br>
                    <b>• Yacht:</b> 5개 동일 숫자 (50점)<br>
                    <b style="color: #f1c40f;">⭐ 상단 합계 63점 이상 시 +35점!</b>
                </div>
            </div>
        </div>
    </div>

   <div id="gameover-overlay" class="overlay">
        <div class="result-box">
            <h1 id="winnerText" style="font-size: 24px; color: #f1c40f; margin-top: 0; margin-bottom: 8px; word-break: keep-all;"></h1>
            <p id="finalScoreMsg" style="font-size: 15px; margin-top: 0; margin-bottom: 15px; color: #bdc3c7;"></p>
            
            <button class="btn-purple" id="captureBtn" onclick="captureScoreboard()" style="width: 100%; margin: 0 0 10px 0; padding: 10px 20px;">
                <i class="fa-solid fa-camera"></i> <span data-i18n="captureBtnTxt">점수판 캡쳐</span>
            </button>
            
            <div style="display: flex; flex-direction: column; gap: 8px;">
                <button class="btn-red" id="levelUpBtn" onclick="triggerLevelUpRematch()" style="display: none; font-size: 15px; width: 100%; margin: 0; padding: 10px 20px;">
                    🔥 <span data-i18n="levelUpBtnTxt">더 강한 상대에게 도전</span>
                </button>
                <div style="display: flex; justify-content: space-between; gap: 10px;">
                    <button class="btn-green" id="rematchBtn" onclick="requestRematch()" style="flex: 1; font-size: 14px; margin: 0; padding: 10px 20px;" data-i18n="rematchBtnTxt">다시하기</button>
                    <button class="btn-blue" onclick="location.reload()" style="flex: 1; font-size: 14px; margin: 0; padding: 10px 20px;" data-i18n="exitBtnTxt">종료</button>
                </div>
            </div>
            <div id="rematchStatus" style="margin-top: 8px; color: #bdc3c7; font-size: 12px; min-height: 14px;"></div>
        </div>
    </div>

    <script>
        const i18n = {
            ko: {
                mainTitle: "🎲 YACHT DICE ONLINE 🎲", patchTitle: "업데이트 내역", nicknameGuide: "상대방에게 보여질 닉네임을 입력해 주세요.",
                idPlaceholder: "아이디 입력 (빈칸 시 랜덤)", loginBtn: "게임 접속",
