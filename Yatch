        function createPerfectRoundedCube(size, radius, segments) {
            const geometry = new THREE.BoxGeometry(size, size, size, segments, segments, segments);
            const position = geometry.attributes.position;
            const half = size / 2;
            for (let i = 0; i < position.count; i++) {
                let x = position.getX(i), y = position.getY(i), z = position.getZ(i);
                let nx = Math.max(-half + radius, Math.min(half - radius, x));
                let ny = Math.max(-half + radius, Math.min(half - radius, y));
                let nz = Math.max(-half + radius, Math.min(half - radius, z));
                const dx = x - nx, dy = y - ny, dz = z - nz;
                const length = Math.sqrt(dx * dx + dy * dy + dz * dz);
                if (length > 0) {
                    position.setXYZ(i, nx + (dx / length) * radius, ny + (dy / length) * radius, nz + (dz / length) * radius);
                }
            }
            geometry.computeVertexNormals();
            return geometry;
        }

