                        break;
                    case 'SURRENDER': handleOpponentSurrender(); break;
                    case 'REMATCH_PUSH': isOppWantRematch = true; handleRematchLogic(); break;
                    case 'REMATCH_START': resetFullGame(data.starterNickname); break;
                }
            });
