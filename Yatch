                catTitle: "항목", subtotalTxt: "상단 합계", bonusTxt: "보너스<br><span style='color: #7f8c8d; font-size: 10px; font-weight: normal;'>(상단 63점 이상 시 +35점)</span>",
                guideTitle: "<i class='fa-solid fa-book'></i> 점수 계산 방법",
