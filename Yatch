                        break;
                    case 'SYNC_HOLD': isHeld[data.index] = data.isHeld; updateUI(); break;
                    case 'SYNC_SCORE': 
                        oppScores[data.category] = data.score; 
                        lastScoredId = `opp-${data.category}`;
