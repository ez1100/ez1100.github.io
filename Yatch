                captureBtnTxt: "점수판 캡쳐", rematchBtnTxt: "다시하기", retryBtnTxt: "현재 난이도 재도전", levelUpBtnTxt: "더 강한 상대에게 도전", exitBtnTxt: "종료", botName: "🤖 알파다이스", userStr: "유저", maxTxt: "최대", fixTxt: "점",
